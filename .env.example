# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

DB_HOST=localhost
DB_PORT=3306
DB_NAME=urlshortener
DB_USER=root
DB_PASSWORD=yourpassword

# Redis (Phase 2)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SECONDS=3600

# Rate limiting (Phase 3) — sliding window on POST /shorten
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Async analytics (Phase 4) — RabbitMQ + MongoDB
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
MONGODB_URI=mongodb://localhost:27017/urlshortener_analytics
ANALYTICS_QUEUE=click_events

# The public base URL used to construct short links
BASE_URL=http://localhost:8000
